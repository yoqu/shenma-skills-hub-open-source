# SkillStack local environment example.
# Copy to `.env` or `backend/.env` and fill real values locally. Do not commit real secrets.

# Feishu OAuth
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_REDIRECT_URI=http://localhost:5173/auth/callback
FEISHU_STATE_TTL_SECONDS=600

# OAuth state HMAC secret（可选）。
# 留空时后端首启会自动生成并持久化到 system_config 表，无需手工配置；
# 生产环境若想固定值或跨实例共享，可显式设置（>=32 字符随机串，例如 openssl rand -base64 48）。
# OAUTH_STATE_SECRET=
# OAUTH_STATE_TTL_SECONDS=600
# OAUTH_FRONTEND_ORIGIN=http://localhost:5173

# Local database
SKILLSTACK_DB_PORT=3307
SKILLSTACK_DB_URL='jdbc:mysql://localhost:3307/skillstack?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true'
SKILLSTACK_DB_USERNAME=skillstack
SKILLSTACK_DB_PASSWORD=skillstack

# Backend security (generate with: openssl rand -base64 48)
SKILLSTACK_JWT_SECRET=replace-with-at-least-32-random-characters
