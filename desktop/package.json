{
  "name": "skillstack-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "SkillStack desktop client",
  "author": "SkillStack",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5174",
    "predev:electron": "npm run build:electron",
    "dev:electron": "VITE_DEV_SERVER_URL=http://127.0.0.1:5174 electron .",
    "build": "tsc -b && vite build && npm run build:electron",
    "build:electron": "node -e \"require('node:fs').rmSync('dist-electron',{recursive:true,force:true})\" && tsc -p tsconfig.electron.json && node -e \"require('node:fs').writeFileSync('dist-electron/package.json', JSON.stringify({ type: 'commonjs' }, null, 2) + '\\n')\"",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "preview": "vite preview",
    "lint": "tsc -b --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "axios": "^1.7.7",
    "electron-log": "^5.4.4",
    "lucide-react": "^0.456.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "yauzl": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/yauzl": "^2.10.3",
    "@vitejs/plugin-react": "^4.3.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "vitest": "^1.6.0"
  },
  "build": {
    "appId": "com.skillstack.desktop",
    "productName": "SkillStack",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "artifactName": "${productName}-${version}-windows-${arch}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "category": "Utility",
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
